# ──────────────────────────────────────────────────────────────────────────────
# Chronos .gitignore — Rust project + SQLite + editor artefacts
# ──────────────────────────────────────────────────────────────────────────────

# Rust / Cargo build artefacts
/target
**/*.rs.bk

# Cargo.lock is intentionally committed for binaries (not libraries).
# See: https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html

# SQLite databases — ephemeral local data, never committed
*.db
*.db-journal
*.db-wal
*.db-shm

# Environment overrides
.env
.env.*

# Editor / IDE temp files
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# macOS system files
.DS_Store

# Linux core dumps
core

# Coverage / profiling
*.profraw
tarpaulin-report.html
lcov.info
